{
  "name": "platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "lhci": "lhci autorun --config=lighthouserc.cjs",
    "db:generate": "pnpm --filter @platform/db generate",
    "db:migrate": "pnpm --filter @platform/db migrate",
    "db:push": "pnpm --filter @platform/db push",
    "db:seed": "pnpm --filter @platform/db seed",
    "db:studio": "pnpm --filter @platform/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "@types/node": "^22.5.5",
    "prettier": "^3.3.3",
    "@lhci/cli": "^0.14.0"
  }
}
