# ──────────────────────────────────────────────
# Database (Neon Postgres)
# DATABASE_URL  → pooled connection, used by the app at runtime
# DIRECT_URL    → direct connection, used by Drizzle for migrations
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/platform?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/platform?sslmode=require"

# ──────────────────────────────────────────────
# Sites app
# The apex host your client domains CNAME to. Subdomains of this
# (e.g. demo-roofing.NEXT_PUBLIC_SITES_HOST) resolve in local/dev.
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITES_HOST="localhost:3000"

# ──────────────────────────────────────────────
# Console app (added in Week 3)
# ──────────────────────────────────────────────
CONSOLE_API_URL="http://localhost:3001"
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# Dev-only auth bypass. When Clerk keys are absent AND this is "1" (and
# NODE_ENV is not "production"), the console runs with a stub owner session
# so Week-3 features are usable before Clerk is wired up. Leave empty / unset
# in any deployed environment.
CONSOLE_DEV_NO_AUTH=""

# --------------------------------------------------
# Stripe billing (added in Week 3 - agency's own retainers)
# When STRIPE_SECRET_KEY is absent the console degrades: the billing
# page renders a "not configured" notice and the webhook returns 400.
# Price ids map plan tiers (basic / growth / scale) to Stripe prices.
# --------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_SCALE=""

# ──────────────────────────────────────────────
# Cloudflare for SaaS (added in Week 4 onboarding flow)
# ──────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# ──────────────────────────────────────────────
# Monitoring
# ──────────────────────────────────────────────
SENTRY_DSN=""
