# ──────────────────────────────────────────────
# Database (Neon Postgres)
# DATABASE_URL  → pooled connection, used by the app at runtime
# DIRECT_URL    → direct connection, used by Drizzle for migrations
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/platform?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/platform?sslmode=require"

# ──────────────────────────────────────────────
# Sites app
# The apex host your client domains CNAME to. Subdomains of this
# (e.g. demo-roofing.NEXT_PUBLIC_SITES_HOST) resolve in local/dev.
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITES_HOST="localhost:3000"

# ──────────────────────────────────────────────
# Console app (added in Week 3)
# ──────────────────────────────────────────────
CONSOLE_API_URL="http://localhost:3001"
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# ──────────────────────────────────────────────
# Cloudflare for SaaS (added in Week 4 onboarding flow)
# ──────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# ──────────────────────────────────────────────
# Monitoring
# ──────────────────────────────────────────────
SENTRY_DSN=""
